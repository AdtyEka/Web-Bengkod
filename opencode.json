{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "shadcn": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@jpisnice/shadcn-ui-mcp-server"
            ]
        },
        "chrome-devtools": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest"
            ]
        }
    }
}