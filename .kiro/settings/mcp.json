{
  "mcpServers": {
    "laravel-boost": {
      "command": "php",
      "args": [
        "artisan",
        "boost:mcp"
      ],
      "autoApprove": [
        "application-info",
        "get-absolute-url",
        "last-error",
        "browser-logs",
        "read-log-entries"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "-y",
        "shadcn@latest",
        "mcp"
      ],
      "disabled": false,
      "autoApprove": [
        "*"
      ]
    }
  }
}