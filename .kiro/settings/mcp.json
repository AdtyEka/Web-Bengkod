{
  "mcpServers": {
    "laravel-boost": {
      "command": "php",
      "args": [
        "artisan",
        "boost:mcp"
      ],
      "autoApprove": [
        "application-info"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "-y",
        "@shadcn/mcp@latest"
      ],
      "disabled": false,
      "autoApprove": []
    }
  }
}